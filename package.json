{
  "name": "mcp-dashboard",
  "version": "1.0.0",
  "type": "module",
  "description": "Interactive MCP Dashboard - Artifacts, Widgets & Workspaces",
  "main": "dist/index.js",
  "bin": {
    "mcp-dashboard": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "build:client": "cd client && npm ci && npm run build",
    "build:all": "npm run build && npm run build:client",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/index.ts",
    "dev:client": "cd client && npm run dev",
    "start": "node dist/index.js",
    "inspector": "npx @modelcontextprotocol/inspector dist/index.js"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.19.1",
    "better-sqlite3": "^11.0.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "nanoid": "^5.0.0",
    "socket.io": "^4.7.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^20.0.0",
    "concurrently": "^9.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.3.0"
  }
}
